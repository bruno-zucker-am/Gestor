{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "ignoreDeprecations": "6.0", 
    "strict": true,
    "moduleResolution": "bundler",
    "types": ["node"],
    "baseUrl": ".", 
    "paths": {
      "@/*": ["src/app/*"],
      "@service/*": ["src/app/service/*"],
      "@model/*": ["src/app/model/*"],
      "@src/*": ["src/*"]
    }
  }
}
